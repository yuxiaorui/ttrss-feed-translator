TRANSLATOR_DATABASE_URL=postgresql://postgres:password@db:5432/postgres
TRANSLATOR_OWNER_UID=1
TRANSLATOR_TARGET_LANGUAGE=zh-CN
# 只翻这些 feed；建议只填你确认是英文源的 feed id。
TRANSLATOR_FEED_IDS=
# 可选：额外按 ttrss_entries.lang 过滤。留空更稳，避免 RSSHub 之类的语言标记误判。
TRANSLATOR_SOURCE_LANGS=
TRANSLATOR_LOOKBACK_HOURS=48
TRANSLATOR_BATCH_SIZE=10
TRANSLATOR_LOOP_INTERVAL_SECONDS=300
TRANSLATOR_REQUIRE_SINGLE_OWNER=true
TRANSLATOR_DRY_RUN=false

TRANSLATOR_API_BASE_URL=https://api.openai.com/v1
TRANSLATOR_API_KEY=replace-me
TRANSLATOR_MODEL=replace-me
TRANSLATOR_REQUEST_TIMEOUT_SECONDS=120
TRANSLATOR_MAX_TEXTS_PER_REQUEST=40
TRANSLATOR_MAX_CHARS_PER_REQUEST=8000
